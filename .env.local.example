# ============================================================
#  Build Saudi — Environment Variables
#  انسخ هذا الملف إلى .env.local وأضف القيم الصحيحة
#  cp .env.local.example .env.local
# ============================================================

# ─────────────────────────────────────
# Supabase — من Supabase → Settings → API
# ─────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY_HERE
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY_HERE

# ─────────────────────────────────────
# Resend — من https://resend.com/api-keys
# ─────────────────────────────────────
RESEND_API_KEY=re_YOUR_RESEND_API_KEY

# ─────────────────────────────────────
# DeepSeek — اختياري لتحليل طلبات المواد وملفات الكميات إلى بنود منظمة
# إذا لم يتم ضبطه، يستخدم الموقع استخراجاً احتياطياً بسيطاً ولا يفشل الطلب
# ─────────────────────────────────────
DEEPSEEK_API_KEY=sk_YOUR_DEEPSEEK_API_KEY
DEEPSEEK_MATERIAL_EXTRACTION_MODEL=deepseek-v4-pro

# ─────────────────────────────────────
# Odoo — نظام العمليات المعتمد (يستبدل ERPNext تدريجياً، Phase 2A)
# ODOO_BASE_URL: رابط قاعدة Odoo Online (مثال: https://yourcompany.odoo.com)
# ODOO_DATABASE: اسم قاعدة البيانات
# ODOO_USERNAME: بريد المستخدم المرتبط بمفتاح API
# ODOO_API_KEY: مفتاح API (وليس كلمة المرور)
# ─────────────────────────────────────
ODOO_BASE_URL=https://yourcompany.odoo.com
ODOO_DATABASE=yourdatabase
ODOO_USERNAME=api-user@example.com
ODOO_API_KEY=YOUR_ODOO_API_KEY

# اختياري — ضبط سلوك الشبكة لعميل Odoo
# ODOO_REQUEST_TIMEOUT=15000
# ODOO_MAX_RETRIES=2

# ─────────────────────────────────────
# أسرار توقيع Tokens — كل سر مستقل تماماً، بلا مشاركة بين الاستخدامات
# كل سر مطلوب إلزامياً في Production (لا قيمة افتراضية) — يفشل التطبيق بوضوح إن غاب
# ─────────────────────────────────────

# OTP_SECRET: توقيع رموز التحقق من البريد (OTP) وtoken التحقق المؤقت بعده
OTP_SECRET=YOUR_RANDOM_SECRET_1

# UPLOAD_TOKEN_SECRET: توقيع رابط ربط الملف المرفوع بسجل المورد (attach token)
UPLOAD_TOKEN_SECRET=YOUR_RANDOM_SECRET_2

# VENDOR_ONBOARDING_TOKEN_SECRET: توقيع رابط دعوة استكمال ملف المورد
# ⚠️ تغيير هذا السر يُبطل فوراً أي رابط دعوة سبق إصداره
VENDOR_ONBOARDING_TOKEN_SECRET=YOUR_RANDOM_SECRET_3

# CRON_SECRET: (محجوز لمرحلة لاحقة — معالج Outbox الدوري) يتحقق أن طلب الـcron قادم من Vercel فعلاً
# غير مُستخدم في الكود بعد في هذي الدفعة
CRON_SECRET=YOUR_RANDOM_SECRET_4

# ─────────────────────────────────────
# Admin Email — يُستخدم لإرسال إشعارات الطلبات الجديدة
# ─────────────────────────────────────
ADMIN_EMAIL=admin@build.sa

# ─────────────────────────────────────
# App URL — رابط الموقع الكامل (بدون / في النهاية)
# ─────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://www.build.sa

# Optional legacy alias used by Vercel projects that already define SITE_URL.
# If both are present, NEXT_PUBLIC_APP_URL wins.
NEXT_PUBLIC_SITE_URL=https://www.build.sa

# ─────────────────────────────────────
# وضع الصيانة — اضبط على true لإغلاق الموقع مؤقتاً
# ─────────────────────────────────────
NEXT_PUBLIC_MAINTENANCE_MODE=false

# ─────────────────────────────────────
# نموذج طلب عرض السعر (/get-quote)
# true = تفعيل النموذج الإلكتروني
# غير مضبوط أو أي قيمة أخرى = إيقاف النموذج وتوجيه العميل لـ sales@build.sa
# ─────────────────────────────────────
# NEXT_PUBLIC_ENABLE_QUOTE_FORM=true

# ─────────────────────────────────────
# ملاحظات التهيئة:
#
# 1. NEXT_PUBLIC_SUPABASE_URL و NEXT_PUBLIC_SUPABASE_ANON_KEY
#    تُضاف تلقائياً عند ربط Supabase من Vercel → Storage
#
# 2. SUPABASE_SERVICE_ROLE_KEY
#    أضفها يدوياً في Vercel → Settings → Environment Variables
#    (لا تُضاف تلقائياً — وهي حساسة جداً، لا تشاركها)
#
# 3. RESEND_API_KEY
#    أنشئ مفتاحاً من resend.com وأضفه في Vercel
#
# 4. تأكد من إعادة النشر بعد إضافة أي متغير جديد
# ─────────────────────────────────────
